{
    "description": "Pipeline Post-Process: Simple cel-shading by post-processing the engine's full PBR lighting result.",
    "version": 1,
    "propertyLayout": {
        "groups": [
            {
                "id": "settings",
                "displayName": "Settings"
            }
        ],
        "properties": {
            "settings": [
                {
                    "id": "litColor",
                    "displayName": "Lit Color",
                    "type": "Color",
                    "defaultValue": [1.0, 1.0, 1.0],
                    "connection": {
                        "type": "ShaderInput",
                        "id": "m_litColor"
                    }
                },
                {
                    "id": "unlitColor",
                    "displayName": "Unlit Color",
                    "type": "Color",
                    "defaultValue": [0.15, 0.15, 0.15],
                    "connection": {
                        "type": "ShaderInput",
                        "id": "m_unlitColor"
                    }
                },
                {
                    "id": "baseColor",
                    "displayName": "Base Color",
                    "type": "Color",
                    "defaultValue": [1.0, 1.0, 1.0],
                    "connection": {
                        "type": "ShaderInput",
                        "id": "m_baseColor"
                    }
                },
                {
                    "id": "roughness",
                    "displayName": "Roughness",
                    "type": "float",
                    "defaultValue": 1.0,
                    "min": 0.0,
                    "max": 1.0,
                    "connection": {
                        "type": "ShaderInput",
                        "id": "m_roughness"
                    }
                },
                {
                    "id": "metallic",
                    "displayName": "Metallic",
                    "type": "float",
                    "defaultValue": 0.0,
                    "min": 0.0,
                    "max": 1.0,
                    "connection": {
                        "type": "ShaderInput",
                        "id": "m_metallic"
                    }
                },
                {
                    "id": "diffuseThreshold",
                    "displayName": "Diffuse Threshold",
                    "type": "float",
                    "defaultValue": 0.5,
                    "min": 0.0,
                    "max": 1.0,
                    "connection": {
                        "type": "ShaderInput",
                        "id": "m_diffuseThreshold"
                    }
                },
                {
                    "id": "specularThreshold",
                    "displayName": "Specular Threshold",
                    "type": "float",
                    "defaultValue": 0.3,
                    "min": 0.0,
                    "max": 1.0,
                    "connection": {
                        "type": "ShaderInput",
                        "id": "m_specularThreshold"
                    }
                }
            ]
        }
    },
    "shaders": [
        {
            "file": "./FullPipeline_MinimalPBR_SimpleCelShaded.shader"
        },
        {
            "file": "Assets/Shaders/ExampleCodeToReferenceGeneratedByAi/Depth_ClaudeOpus/StencilExcludeDepthPass_ClaudeOpus.shader"
        },
        {
            "file": "Shaders/Shadow/Shadowmap.shader"
        }
    ]
}
