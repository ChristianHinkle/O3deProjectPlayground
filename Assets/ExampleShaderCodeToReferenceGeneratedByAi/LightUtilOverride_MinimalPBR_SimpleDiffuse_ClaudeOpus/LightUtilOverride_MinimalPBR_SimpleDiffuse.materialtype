{
    "description": "LightUtil Override: Simple diffuse using LightUtil overrides. Custom diffuse function applied per-light via the engine's pipeline.",
    "version": 1,
    "propertyLayout": {
        "groups": [
            {
                "id": "settings",
                "displayName": "Settings"
            }
        ],
        "properties": {
            "settings": [
                {
                    "id": "baseColor",
                    "displayName": "Base Color",
                    "type": "Color",
                    "defaultValue": [1.0, 1.0, 1.0],
                    "connection": {
                        "type": "ShaderInput",
                        "id": "m_baseColor"
                    }
                }
            ]
        }
    },
    "shaders": [
        {
            "file": "./LightUtilOverride_MinimalPBR_SimpleDiffuse.shader"
        },
        {
            "file": "Assets/Shaders/ExampleCodeToReferenceGeneratedByAi/Depth_ClaudeOpus/StencilExcludeDepthPass_ClaudeOpus.shader"
        },
        {
            "file": "Shaders/Shadow/Shadowmap.shader"
        }
    ]
}
