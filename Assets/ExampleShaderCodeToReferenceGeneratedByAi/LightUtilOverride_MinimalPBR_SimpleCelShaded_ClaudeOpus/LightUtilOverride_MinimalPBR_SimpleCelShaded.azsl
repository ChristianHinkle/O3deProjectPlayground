#pragma once

// LightUtil Override: Use the engine's lighting pipeline with custom LightUtil overrides.
// Each light type's Apply() is overridden to use CelShadeDiffuse() instead of the
// engine's DiffuseLambertian(). The engine handles light iteration, culling, attenuation
// init, shadows, and IBL. We only replace the per-light shading math.
//
// Key advantage over Approach A: new light types (capsule, quad, polygon, future types)
// fall back to PBR defaults instead of being invisible.
//
// Key advantage over Pipeline Post-Process: per-light control. Each light individually gets
// cel-shaded rather than post-processing the aggregate result.

#define FORCE_IBL_IN_FORWARD_PASS 1
#define FORCE_OPAQUE 1

#include <scenesrg_all.srgi>
#include <viewsrg_all.srgi>
#include <Atom/Features/PBR/DefaultObjectSrg.azsli>
#include <Atom/RPI/ShaderResourceGroups/DefaultDrawSrg.azsli>
#include <Atom/Features/InstancedTransforms.azsli>
#include <Atom/Features/Pipeline/Forward/ForwardPassSrg.azsli>
#include <Atom/Features/Pipeline/Forward/ForwardPassOutput.azsli>
#include <Atom/Features/SrgSemantics.azsli>

// --- Prerequisites: Surface, LightingData, and BRDF must be defined before custom utils ---
#include <Atom/Features/PBR/LightingOptions.azsli>
#include <Atom/Features/PBR/Lighting/LightingData.azsli>
#include <Atom/Features/PBR/Surfaces/StandardSurface.azsli>
#include <Atom/Features/PBR/LightingUtils.azsli>
#include <Atom/Features/PBR/Microfacet/Brdf.azsli>
#include <Atom/Features/SampleBrdfMap.azsli>
#include <Atom/Features/GoboTexture.azsli>

// --- Custom LightUtil overrides (uses Surface/LightingData, defines #define macros) ---
#include "CelShadeLightUtils.azsli"

// --- StandardLighting: prereqs skipped via #pragma once, defines GetDiffuse/GetSpecular, includes light loops ---
#include <Atom/Features/PBR/Lighting/StandardLighting.azsli>
#include <Atom/Features/PBR/Lights/IblForward.azsli>
#include <Atom/Features/PBR/Decals.azsli>

ShaderResourceGroup MaterialSrg : SRG_PerMaterial
{
    float3 m_litColor;
    float3 m_unlitColor;
}

struct VSInput
{
    float3 m_position : POSITION;
    float3 m_normal : NORMAL;
    float4 m_tangent : TANGENT;
};

struct VSOutput
{
    precise linear centroid float4 m_position : SV_Position;
    float3 m_normal : NORMAL;
    float4 m_tangent : TANGENT;
    float3 m_worldPosition : UV0;
    uint m_instanceId : SV_InstanceID;
};

VSOutput MainVS(VSInput IN, uint instanceId : SV_InstanceID)
{
    VSOutput OUT;
    OUT.m_instanceId = instanceId;

    float3 worldPosition = mul(GetObjectToWorldMatrix(instanceId), float4(IN.m_position, 1.0)).xyz;
    OUT.m_worldPosition = worldPosition;
    OUT.m_position = mul(ViewSrg::m_viewProjectionMatrix, float4(worldPosition, 1.0));
    OUT.m_normal = IN.m_normal;
    OUT.m_tangent = IN.m_tangent;

    return OUT;
}

ForwardPassOutput MainPS(VSOutput IN)
{
    real4x4 objectToWorld = real4x4(GetObjectToWorldMatrix(IN.m_instanceId));
    real3x3 objectToWorldIT = real3x3(GetObjectToWorldMatrixInverseTranspose(IN.m_instanceId));

    float3 normalWS, tangentWS, bitangentWS;
    ConstructTBN(real3(IN.m_normal), real4(IN.m_tangent), objectToWorld, objectToWorldIT, normalWS, tangentWS, bitangentWS);

    // --- Surface (white albedo so CelShadeDiffuse returns pure light contribution) ---
    Surface surface;
    surface.position = IN.m_worldPosition.xyz;
    surface.normal = normalWS;
    surface.vertexNormal = normalWS;
    surface.roughnessLinear = 1.0;
    surface.CalculateRoughnessA();
    surface.SetAlbedoAndSpecularF0(float3(1.0, 1.0, 1.0), 0.5, 0.0);  // specularF0Factor=0.5 (standard dielectric), metallic=0
    surface.clearCoat.InitializeToZero();
    surface.lightingChannels = 0xFFFFFFFF; // Receive light from all channels

    // --- Light culling ---
    LightCullingTileIterator tileIterator;
    tileIterator.Init(IN.m_position, PassSrg::m_lightListRemapped, PassSrg::m_tileLightData);

    // --- LightingData ---
    float3 views[MAX_SHADING_VIEWS];
    views[0] = ViewSrg::m_worldPosition.xyz;

    LightingData lightingData;
    lightingData.Init(surface.position, surface.normal, surface.roughnessLinear, views);
    // Keep PBR energy conservation: Fresnel splits energy between diffuse and specular.
    // Both sides will be quantized into bands, so the smooth Fresnel gradient becomes a hard edge.
    lightingData.specularResponse = FresnelSchlickWithRoughness(lightingData.GetSpecularNdotV(), surface.specularF0, surface.roughnessLinear);
    lightingData.diffuseResponse = 1.0f - lightingData.specularResponse;

    // --- Lighting (each light uses CelShadeDiffuse via our custom LightUtils for diffuse, ---
    // --- and the engine's standard GetSpecularLighting for specular)                      ---
    ApplyDecals(tileIterator, surface);
    ApplyDirectLighting(surface, lightingData, IN.m_position, tileIterator);
    // ApplyIblForward adds both diffuse IBL (ambient from environment, including reflection
    // probe blending) and specular IBL (Fresnel-based reflections) to lightingData.
    ApplyIblForward(surface, lightingData);
    lightingData.FinalizeLighting();

    // Quantize diffuse into cel-shading bands.
    // The diffuse result includes per-light cel-shaded contributions (from our custom LightUtils)
    // plus diffuse IBL (from ApplyIblForward).
    float diffuseLuminance = dot(lightingData.diffuseLighting, float3(0.2126, 0.7152, 0.0722));
    float diffuseBand = step(0.5, diffuseLuminance);
    float3 celDiffuse = lerp(MaterialSrg::m_unlitColor, MaterialSrg::m_litColor, diffuseBand);

    // Quantize specular into cel-shading bands.
    // specularLighting[0] is the combined result of per-light highlights + IBL reflections.
    // Stepping it quantizes all specular sources together.
    float specLuminance = dot(lightingData.specularLighting[0], float3(0.2126, 0.7152, 0.0722));
    float specBand = step(0.3, specLuminance);
    float3 celSpecular = specBand * MaterialSrg::m_litColor;

    // --- Output ---
    PbrLightingOutput lightingOutput = GetPbrLightingOutput(surface, lightingData, 1.0);

    ForwardPassOutput OUT;
    OUT.m_diffuseColor = float4(celDiffuse, -1);
    OUT.m_specularColor = float4(celSpecular, 1.0);
    // Zero specularF0 so the reflection pipeline (ReflectionGlobalFullscreen, ReflectionComposite)
    // produces no reflections for our pixels. Roughness = 1.0 in alpha.
    OUT.m_specularF0 = float4(0.0, 0.0, 0.0, 1.0);
    OUT.m_albedo = lightingOutput.m_albedo;
    // Zero normal signals "no IBL, no reflections" to the reflection pipeline.
    // Using lightingOutput.m_normal would encode o_enableIBL=true in the alpha,
    // causing the reflection passes to add unwanted specular IBL on top of our cel result.
    OUT.m_normal = float4(0.0, 0.0, 0.0, 0.0);
    return OUT;
}
